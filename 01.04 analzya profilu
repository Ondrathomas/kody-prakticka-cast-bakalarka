import pandas as pd

# 0. KROK: Načtení dat
df_audit = pd.read_csv(r"C:\Users\ondra\OneDrive\Plocha\cez-data\Prvotni_Dataset_Surovy.csv")

# 1. KROK: Analýza profilů (Kompletní četnost všech profilů v datasetu)
print("Provádím hloubkovou analýzu profilů v surovém datasetu...")
vsechny_profily = df_audit['profile'].value_counts()

pocet_raw = len(df_audit)

# 2. KROK: Definice skupin profilů 
# Kumulativní registry (hledáme profily začínající na +E nebo -E)
profily_cumul = [p for p in vsechny_profily.index if p.startswith('+E') or p.startswith('-E')]
pocet_cumul = sum([vsechny_profily[p] for p in profily_cumul])

# Relevantní výkonové profily (čtvrthodiny)
pocet_a15  = vsechny_profily.get('+A15', 0)
pocet_ri15 = vsechny_profily.get('+Ri15', 0)
pocet_rc15 = vsechny_profily.get('+Rc15', 0)
pocet_fve  = vsechny_profily.get('-A15', 0)
pocet_relevant = pocet_a15 + pocet_ri15 + pocet_rc15 + pocet_fve

# Počet řádků pro výkonovou analýzu
pocet_pro_analuzu = pocet_raw - pocet_cumul

# Ostatní záznamy (Balast a šum) - profily, které nespadají ani do jedné skupiny
profily_relevantni_a_cumul = ['+A15', '+Ri15', '+Rc15', '-A15'] + profily_cumul
zbytek_sum = sum([vsechny_profily[p] for p in vsechny_profily.index if p not in profily_relevantni_a_cumul])


# --- TISK VÝSLEDKŮ (Čisté formátování bez syntaktických chyb) ---
def format_num(n):
    return f"{n:,}".replace(",", " ")

print("\n" + "=" * 85)
print(f"{'Parametr analýzy (Kód)':<35} {'Technický popis (Praxe)':<35} {'Počet řádků':>12}")
print("-" * 85)
print(f"{'Celkový počet řádků':<35} {'Surová data (všechny záznamy)':<35} {format_num(pocet_raw):>12}")
print(f"{'Vyfiltrované stavy (+E*, -E*)':<35} {'Celkové registry (kumulativní)':<35} {format_num(pocet_cumul):>12}")
print(f"{'Počet řádků pro analýzu':<35} {'Čtvrthodinová výkonová data':<35} {format_num(pocet_pro_analuzu):>12}")
print("-" * 85)
print(f"{'Záznamy dle profilů':<35} {'Relevantní profily celkem':<35} {format_num(pocet_relevant):>12}")
print(f"  profil +A15" + " " * 22 + f"| {'Činný odběr (aktivní výkon)':<35} {format_num(pocet_a15):>12}")
print(f"  profil +Ri15" + " " * 21 + f"| {'Jalový induktivní odběr':<35} {format_num(pocet_ri15):>12}")
print(f"  profil +Rc15" + " " * 21 + f"| {'Jalový kapacitní odběr':<35} {format_num(pocet_rc15):>12}")
print(f"  profil -A15" + " " * 22 + f"| {'Činná dodávka (přetoky FVE)':<35} {format_num(pocet_fve):>12}")
print("-" * 85)
print(f"{'Ostatní záznamy':<35} {'Nezařazená data (balast a šum)':<35} {format_num(zbytek_sum):>12}")
print("=" * 85)


